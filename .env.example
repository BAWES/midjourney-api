# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/midjourney_api

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord User Token (for Interaction API — see docs/user-token-guide.md)
DISCORD_USER_TOKEN=your_user_token_here

# Discord Channel ID (right-click channel > Copy ID, with Developer Mode enabled)
MJ_CHANNEL_ID=123456789012345678

# Midjourney concurrency (Standard=3, Pro=12)
MJ_MAX_CONCURRENT_JOBS=3

# Task timeout in seconds
MJ_TASK_TIMEOUT_SECONDS=120

# Platform-wide daily limit across all API keys
PLATFORM_DAILY_LIMIT=100

# API prefix
API_V1_PREFIX=/api/v1
