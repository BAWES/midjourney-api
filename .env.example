# Discord Bot Token (from https://discord.com/developers/applications)
# Used for WebSocket gateway monitoring
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord User Token (your personal token for sending /imagine commands)
# Get from browser DevTools console on discord.com
DISCORD_USER_TOKEN=your_user_token_here

# Discord Channel ID (your private channel where MJ bot is installed)
# Right-click channel > Copy ID (Developer Mode must be on)
MJ_CHANNEL_ID=123456789012345678

# Midjourney concurrency (Standard=3, Pro/Mega=12)
MJ_MAX_CONCURRENT_JOBS=3

# Generation timeout in seconds
GENERATION_TIMEOUT_SECONDS=120

# Auth token — bots passing this as Bearer token can call the MCP
# Used for Universe bot integration
MCP_AUTH_TOKEN=change-me-in-production
