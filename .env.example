# Midjourney MCP env — copy to .env and fill in
# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
# Discord User Token (your personal token)
DISCORD_USER_TOKEN=
# Discord channel where Midjourney bot is installed
MJ_CHANNEL_ID=
# Max concurrent jobs (Standard=3, Pro/Mega=12)
MJ_MAX_CONCURRENT_JOBS=3
# Generation timeout in seconds
GENERATION_TIMEOUT_SECONDS=180
# Upscale timeout in seconds
UPSCALE_TIMEOUT_SECONDS=120
# Auth token for Universe bot calls (same as Imagine MCP)
DESIGNER_MCP_TOKEN=
# Server
HOST=0.0.0.0
PORT=8005
